# ── Blockchain — Base Sepolia ─────────────────────────────────────────────────
# Get a free RPC from https://alchemy.com or use the public endpoint
BASE_TESTNET_RPC_URL=https://sepolia.base.org

# Relayer wallet private key
# This is 0xF2ba3b7b3CC269354d4F770549733B5b9e6813Ca (from deployments.json)
# Must have Base Sepolia ETH for gas fees
RELAYER_PRIVATE_KEY=0xYourRelayerPrivateKey

# Deployed contract addresses (DO NOT CHANGE — already live on Base Sepolia)
ESCROW_CONTRACT_ADDRESS=0xaC11528c36A05C904Bead5Ed3a74d4e40Dd38bfE
MOCK_USDC_ADDRESS=0xB9a0E369995c03d966470D4E86b1bdbAD9bd7dc2

# ── Backend connection ────────────────────────────────────────────────────────
# URL of the deployed Firebase Functions API
# Local dev: http://127.0.0.1:5001/YOUR_PROJECT_ID/us-central1/api
# Production: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/api
BACKEND_API_URL=http://127.0.0.1:5001/your-project-id/us-central1/api

# Must match RELAYER_API_SECRET in the backend .env
RELAYER_API_SECRET=your_relayer_shared_secret_min_32_chars

# ── Operational (safe defaults — adjust if needed) ────────────────────────────
LOG_LEVEL=info
CONFIRMATIONS=2
POLLING_INTERVAL_MS=4000
MAX_RETRIES=5
RETRY_DELAY_MS=2000
