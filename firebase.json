{
  "functions": {
    "source": "services/functions",
    "runtime": "nodejs20",
    "secrets": [
      "TREASURY_PRIVATE_KEY",
      "FB_PRIVATE_KEY",
      "FB_CLIENT_EMAIL",
      "RELAYER_API_SECRET"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "apps/web/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  }
}
