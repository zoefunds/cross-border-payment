# ─── Blockchain / Hardhat ─────────────────────────────────────────────────

# Your deployer wallet private key (NEVER commit the real .env)
# Export from MetaMask: Account Details → Export Private Key
DEPLOYER_PRIVATE_KEY=0xyour_private_key_here

# Base Sepolia RPC URL
# Get free one from: https://www.alchemy.com or https://www.quicknode.com
BASE_TESTNET_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# ─── Relayer Service ──────────────────────────────────────────────────────

# Relayer wallet private key (separate from deployer — security best practice)
RELAYER_PRIVATE_KEY=0xyour_relayer_private_key_here

# Deployed contract addresses (filled after Step 5)
MOCK_USDC_ADDRESS=
ESCROW_CONTRACT_ADDRESS=

# Backend API endpoint (your Firebase Functions URL)
BACKEND_API_URL=https://your-project.cloudfunctions.net

# Internal secret for relayer → backend communication
RELAYER_API_SECRET=your_strong_random_secret_here

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
REPORT_GAS=false
